# Copie para .env e preencha. Não commite o ficheiro .env.

# --- Senha do painel (/ , /ver e APIs sensíveis) ---
# Se definir LAB_PANEL_PASSWORD, o painel exige login em /lab-login.
# O link /b e POST /api/lab-report + GET /api/server-meta ficam públicos (alvo não precisa da senha).
# Gere uma senha forte; em HTTPS defina também FLASK_SESSION_COOKIE_SECURE=1.
# LAB_PANEL_PASSWORD=
# FLASK_SECRET_KEY=   # obrigatório em produção (string longa aleatória); se vazio com senha, gera-se uma ao arrancar
# FLASK_SESSION_COOKIE_SECURE=1

# --- Proxy reverso (subcaminho / HTTPS) ---
# Se o painel estiver atrás de nginx, Traefik, etc. com X-Forwarded-Proto / X-Forwarded-For,
# defina TRUST_PROXY=1. O prefixo (X-Forwarded-Prefix) só é aplicado se também definir:
# TRUST_X_FORWARDED_PREFIX=1
# TRUST_PROXY=1

# --- PostgreSQL (opcional) ---
# Se definir DATABASE_URL ou POSTGRES_HOST, o app usa PostgreSQL em vez de SQLite.
# Exemplo URL (substitua user, password, host, porta, base):
# DATABASE_URL=postgresql://usuario:senha@localhost:5432/cyber_awareness_lab

DATABASE_URL=

# Alternativa ao URL (comum em servidores / Docker / ambiente Conversys):
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# --- Limites (opcional) ---
# Máximo de linhas na tabela de coletas /b; 0 = sem limite (recomendado só com PostgreSQL).
# Por omissão: SQLite 200; PostgreSQL sem limite.
# LAB_BEACON_MAX=0

# Máximo de eventos de auditoria; 0 = sem limite.
# LAB_AUDIT_MAX=5000
